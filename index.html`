        const stocks = Object.keys(briefsData);
        const contentArea = document.getElementById('content-area');
        const listArea = document.getElementById('stock-list');

        // Generate stock cards
        stocks.forEach(ticker => {
            const card = document.createElement('div');
            card.className = 'stock-card';
            card.textContent = ticker;
            card.onclick = () => loadBrief(ticker, card);
            listArea.appendChild(card);
        });

        function loadRealTimeChart(ticker) {
            if (typeof TradingView === 'undefined') {
                console.error('TradingView library not loaded');
                return;
            }
            new TradingView.widget({
                "width": "100%",
                "height": 500,
                "symbol": "NASDAQ:" + ticker,
                "interval": "D",
                "timezone": "Etc/UTC",
                "theme": "dark",
                "style": "1",
                "locale": "th",
                "toolbar_bg": "#f1f3f6",
                "enable_publishing": false,
                "hide_side_toolbar": false,
                "allow_symbol_change": true,
                "container_id": "tradingview_chart"
            });
        }

        function loadBrief(ticker, element) {
            document.querySelectorAll('.stock-card').forEach(c => c.classList.remove('active'));
            element.classList.add('active');

            const markdown = briefsData[ticker];

            if (!markdown) {
                contentArea.innerHTML = `<div class="placeholder" style="color: #ef4444;">Error: ไม่พบข้อมูลสำหรับ ${ticker}</div>`;
                return;
            }

            contentArea.innerHTML = `
                <div id="chart-container" style="height: 500px; width: 100%; margin-bottom: 20px;">
                    <div id="tradingview_chart"></div>
                </div>
                <div class="markdown-body">
                    ${marked.parse(markdown)}
                </div>
            `;

            loadRealTimeChart(ticker);
        }
    </script>
